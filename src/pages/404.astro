---
import BaseLayout from "../components/layout/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<BaseLayout title="404 — Página no encontrada | Daniel Santamaría">
  <Header />
  <main class="min-h-screen flex items-center justify-center px-6 pt-16">
    <div class="text-center max-w-md">
      <p class="font-display font-bold text-accent text-8xl mb-2">404</p>
      <h1 class="font-display font-bold text-2xl text-copy mb-3">
        Datos no encontrados
      </h1>
      <p class="text-muted text-sm mb-2">
        <span class="font-mono text-accent/80">Error rate: 100%</span> en esta ruta.
      </p>
      <p class="text-muted text-sm mb-8">
        La página que buscas no existe o fue movida.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-bg font-semibold text-sm hover:bg-accent/90 transition-colors duration-200"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>

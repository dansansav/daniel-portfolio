---
import Badge from "./Badge.astro";
import type { Dashboard } from "../../lib/dashboards";

interface Props {
  dashboard: Dashboard;
  reversed?: boolean;
}

const { dashboard, reversed = false } = Astro.props;
const { id, title, description, tags, images, highlights, clickHint } = dashboard;
const galleryId  = `gallery-${id}`;
const trackId    = `track-${id}`;
const lightboxId = `lightbox-${id}`;
const imageCount = images.length;
---

<div class={`animate-on-scroll grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center ${reversed ? "lg:[&>*:first-child]:order-2" : ""}`}>

  <!-- Content -->
  <div class="flex flex-col gap-5">
    <h3 class="font-display font-bold text-xl md:text-2xl text-copy leading-snug">{title}</h3>

    <p class="lang-es text-muted leading-relaxed text-sm md:text-base">{description.es}</p>
    <p class="lang-en hidden text-muted leading-relaxed text-sm md:text-base">{description.en}</p>

    <!-- Highlights ES -->
    <ul class="lang-es flex flex-col gap-2.5 my-1">
      {highlights.es.map((h) => (
        <li class="flex items-start gap-2.5 text-sm text-copy/80">
          <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent shrink-0" />{h}
        </li>
      ))}
    </ul>

    <!-- Highlights EN -->
    <ul class="lang-en hidden flex flex-col gap-2.5 my-1">
      {highlights.en.map((h) => (
        <li class="flex items-start gap-2.5 text-sm text-copy/80">
          <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent shrink-0" />{h}
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap gap-2 mt-1">
      {tags.map((tag) => <Badge label={tag} variant="accent" />)}
    </div>
  </div>

  <!-- Gallery -->
  <div class="flex flex-col gap-3">
    <div id={galleryId} class="relative">
      <div class="gallery-viewport">
        <div class="gallery-track" id={trackId}>
          {images.map((src, i) => (
            <button
              class="gallery-slide min-w-full cursor-zoom-in border-0 bg-transparent p-0"
              data-lightbox={lightboxId}
              data-src={src}
              aria-label={`Ver ${title} — imagen ${i + 1}`}
            >
              <img
                src={src}
                alt={`${title} — página ${i + 1}`}
                loading={i === 0 ? "eager" : "lazy"}
                class="w-full h-auto object-cover block"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <div class="hidden w-full aspect-video bg-surface border border-border rounded-lg items-center justify-center flex-col gap-3 text-muted">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span class="text-xs">Imagen no disponible</span>
              </div>
            </button>
          ))}
        </div>
      </div>

      {imageCount > 1 && (
        <>
          <button class="gallery-prev absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-bg/80 border border-border hover:border-accent hover:text-accent text-muted flex items-center justify-center transition-colors duration-200 backdrop-blur-sm" aria-label="Anterior">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="gallery-next absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-bg/80 border border-border hover:border-accent hover:text-accent text-muted flex items-center justify-center transition-colors duration-200 backdrop-blur-sm" aria-label="Siguiente">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </>
      )}
    </div>

    {imageCount > 1 && (
      <div class="flex items-center justify-center gap-1.5" id={`dots-${id}`}>
        {images.map((_, i) => (
          <button class={`gallery-dot ${i === 0 ? "active" : ""}`} data-index={i} aria-label={`Imagen ${i + 1}`} />
        ))}
      </div>
    )}

    <p class="text-xs text-muted text-center">
      <span class="lang-es">{clickHint.es}</span>
      <span class="lang-en hidden">{clickHint.en}</span>
    </p>
  </div>
</div>

<!-- Lightbox -->
<dialog id={lightboxId}>
  <button class="lightbox-close absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-surface border border-border text-muted hover:text-copy flex items-center justify-center transition-colors" aria-label="Cerrar">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <img id={`lightbox-img-${id}`} src="" alt="" class="block max-w-[90vw] max-h-[85vh] object-contain" />
</dialog>

<script define:vars={{ galleryId, trackId, lightboxId, id, imageCount }}>
  const track      = document.getElementById(trackId);
  const dots       = document.querySelectorAll(`#dots-${id} .gallery-dot`);
  const lightbox   = document.getElementById(lightboxId);
  const lightboxImg = document.getElementById(`lightbox-img-${id}`);
  let current = 0;

  function goTo(n) {
    current = ((n % imageCount) + imageCount) % imageCount;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle("active", i === current));
  }

  const container = document.getElementById(galleryId);
  container.querySelector(".gallery-prev")?.addEventListener("click", () => goTo(current - 1));
  container.querySelector(".gallery-next")?.addEventListener("click", () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

  document.querySelectorAll(`[data-lightbox="${lightboxId}"]`).forEach((btn) => {
    btn.addEventListener("click", () => {
      lightboxImg.src = btn.dataset.src;
      lightbox.showModal();
    });
  });

  lightbox.querySelector(".lightbox-close").addEventListener("click", () => lightbox.close());
  lightbox.addEventListener("click", (e) => { if (e.target === lightbox) lightbox.close(); });
</script>

---
import SectionTitle from "../ui/SectionTitle.astro";
import ProjectCard from "../ui/ProjectCard.astro";
import { pythonProjects } from "../../lib/python-projects";
---

<section id="python" class="bg-surface py-24">
  <div class="max-w-6xl mx-auto px-6">
    <SectionTitle
      titleEs="Python"
      subtitleEs="Análisis exploratorio, estadística inferencial y visualización de datos con Pandas, SciPy y Seaborn."
      subtitleEn="Exploratory analysis, inferential statistics and data visualization with Pandas, SciPy and Seaborn."
    />
    <div class="flex flex-col gap-8">
      {pythonProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
